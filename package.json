{
  "name": "limpanome",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --loader tsx server/_core/index.ts",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "preview": "vite preview",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "wouter": "^3.1.0",
    "trpc": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@trpc/client": "^11.0.0",
    "express": "^4.18.2",
    "drizzle-orm": "^0.30.0",
    "mysql2": "^3.6.5",
    "zod": "^3.22.4",
    "sonner": "^1.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vite": "^7.1.9",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.10",
    "drizzle-kit": "^0.20.14",
    "tsx": "^4.7.0",
    "vitest": "^2.1.9",
    "esbuild": "^0.20.0"
  }
}
